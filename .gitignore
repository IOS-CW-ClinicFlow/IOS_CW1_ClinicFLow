# macOS system files
.DS_Store

# Xcode build files
build/
DerivedData/

# Xcode user data (per-user, do NOT track)
*.xcuserdatad/
*.xcuserstate
*.moved-aside
*.pbxuser
*.perspectivev3

# Xcode workspace settings
xcshareddata/

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# Xcode archives
*.xcarchive

# Temporary files
*.swp
*.lock
*.hmap

# Xcode indexing and logs
*.xcactivitylog
*.xccheckout
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Playgrounds
timeline.xctimeline
playground.xcworkspace

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Other common IDE files
*.orig
